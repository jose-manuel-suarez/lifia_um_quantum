# Example environment configuration for lifia_um_quantum workflow
# Set the target execution ecosystem (e.g. QISKIT)
ECOSYSTEM=QISKIT

# Path to the input specification (JSON) or unitary description
INPUT_FILE=abstraction2.json

# Starting abstraction level (1..6). If omitted, the runner will try to read
# "abstraction_level" from the input file and fall back to 1.
INPUT_LEVEL=2

# Optional: where intermediate/outputs are written
OUTPUT_DIR=out

# Optional log file path
LOG_FILE=workflow.log
