# Configuración de entorno de ejemplo para el flujo de trabajo lifia_um_quantum
# A partir de este archivo se puede generar la configuración de entorno definitiva
# >cp .env-example .env

# Define el ecosistema de ejecución objetivo, es decir, el lenguaje a probar (por ejemplo: QISKIT)
ECOSYSTEM=QISKIT

# Ruta al archivo de especificación de entrada (JSON) o descripción unitaria
INPUT_FILE='abstraction2.json'

# Nivel de abstracción inicial (1..6). Si se omite, el ejecutor intentará leer
# 'abstraction_level' desde el archivo de entrada; si no existe, por defecto será 1.
INPUT_LEVEL=2

# Directorio donde se configuran los archivos de entrada
INPUT_DIR='/input'

# Directorio donde se generan los archivos de salida
OUTPUT_DIR=/output

# Parametrizaciones relacionadas con el Logging
LOG_ALLOWED=True        # Cambia a False para desactivar completamente el logging (útil en producción o CI/CD)
LOG_DIR='/logs'         # Ruta donde los archivos de log serán almacenados. Asegúrate de que esta ruta exista o se pueda crear.
LOG_LEVEL='DEBUG'       # Cambia a DEBUG para ver trazas matemáticas detalladas, o ERROR en producción
LOG_COLOR=True          # Pónlo en False si vas a correr esto en un servidor CI/CD sin soporte de color
LOG_DISABLE_FILE=False

# Cantidad de qubits utilizados
# En base a esta configuración se determina la dimensión de la matriz de densidad
CANT_QUBITS=3
